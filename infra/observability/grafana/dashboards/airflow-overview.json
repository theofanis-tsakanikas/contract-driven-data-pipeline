{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "title": "Airflow — Pipeline Observability",
  "tags": ["airflow", "etl"],
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "refresh": "10s",
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Monitoring target up",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "mappings": [{ "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }], "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=\"airflow-statsd\"}" }]
    },
    {
      "id": 2, "type": "stat", "title": "Scheduler heartbeat (per min)",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(airflow_scheduler_heartbeat[5m])) * 60" }]
    },
    {
      "id": 3, "type": "timeseries", "title": "Task finishes by state",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (state) (airflow_task_finish_total)", "legendFormat": "{{state}}" }]
    },
    {
      "id": 4, "type": "timeseries", "title": "DAG run duration — success (s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "pointSize": 6 } }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "airflow_dagrun_duration_success_seconds", "legendFormat": "{{dag_id}}" }]
    },
    {
      "id": 5, "type": "timeseries", "title": "Task duration by stage (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "bars", "fillOpacity": 70 } }, "overrides": [] },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (task_id) (airflow_task_duration_seconds)", "legendFormat": "{{task_id}}" }]
    },
    {
      "id": 10, "type": "row", "title": "Data Quality (emitted by the Spark clean task)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }, "collapsed": false, "panels": []
    },
    {
      "id": 6, "type": "gauge", "title": "Accept rate (last run)",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "green", "value": 0.8 }] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "airflow_dq_accept_rate" }]
    },
    {
      "id": 7, "type": "stat", "title": "Accepted vs rejected (last run)",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed" } }, "overrides": [ { "matcher": { "id": "byName", "options": "accepted" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }, { "matcher": { "id": "byName", "options": "rejected" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] } ] },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "airflow_dq_accepted", "legendFormat": "accepted", "instant": true },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "airflow_dq_rejected", "legendFormat": "rejected", "instant": true }
      ]
    },
    {
      "id": 8, "type": "barchart", "title": "Rejections by reason (last run)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 80 } }, "overrides": [] },
      "options": { "orientation": "horizontal", "xTickLabelRotation": 0, "showValue": "always" },
      "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "airflow_dq_rejected_by_reason", "legendFormat": "{{reason}}", "instant": true }]
    },
    {
      "id": 9, "type": "timeseries", "title": "Accepted / rejected over time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15, "pointSize": 7, "showPoints": "always" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "airflow_dq_accepted", "legendFormat": "accepted" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "airflow_dq_rejected", "legendFormat": "rejected" }
      ]
    }
  ]
}
