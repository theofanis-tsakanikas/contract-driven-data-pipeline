# Copy to .env and fill in real values. The .env file is gitignored.
# Loaded by docker compose via --env-file .env and mounted into all Airflow
# services (env_file in infra/docker-compose.yml).
#
# Keep comments on their own lines: some of these values are interpolated into
# the AIRFLOW_CONN_* JSON connection strings, and not every docker compose
# version strips trailing inline comments from .env values.

# === 🗄️ PostgreSQL Instance Settings (Database) ===
DB_USER=airflow
DB_PASS=change_me
# DB_HOST = container_name of the postgres service
DB_HOST=airflow-docker-postgres-1
DB_PORT=5432

# === 🎯 Databases ===
# POSTGRES_DB = Airflow internal metadata DB
POSTGRES_DB=airflow
# TARGET_DB = cleaned analytics data (dbt + loader target)
TARGET_DB=user_data
# DEFAULT_DB = bootstrap DB used to CREATE the target DB
DEFAULT_DB=postgres

# === 🌐 Airflow Web UI Admin (created by infra/init.sh) ===
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=change_me
AIRFLOW_ADMIN_EMAIL=admin@example.com

# === 📊 pgAdmin UI Credentials ===
PGADMIN_MAIL=admin@example.com
PGADMIN_PASS=change_me

# === 📈 Grafana UI (pipeline observability; optional, defaults admin/admin) ===
GRAFANA_USER=admin
GRAFANA_PASS=change_me

# === ☁️ AWS S3 Configuration (from your dedicated IAM user) ===
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=eu-central-1
# S3_BUCKET_NAME = globally-unique bucket name (provisioned by infra/terraform; matches the data_lake_bucket_name there)
S3_BUCKET_NAME=your-globally-unique-bucket-name
# S3_FILE_KEY = fallback key — the DAG overrides this per run with raw/dt=<ds>/dirty-data.csv
S3_FILE_KEY=raw/dirty-data.csv

# === 📂 Local Staging Paths (inside the containers) ===
# N_DIRTY_RECORDS = how many synthetic rows the ingestion generates (default 1000;
# lower it to e.g. 100 for a quicker demo). Costs are negligible at this scale.
N_DIRTY_RECORDS=1000
LOCAL_DIRTY_PATH=/opt/airflow/data/dirty_data.csv
LOCAL_CLEAN_FOLDER=/opt/airflow/data/clean_data
LOCAL_CLEAN_PATH=/opt/airflow/data/clean_data.csv
# Rejected rows are quarantined here (with a rejection_reason) instead of vanishing;
# the per-run data-quality summary (accept rate, rejections by reason) lands in DQ_REPORT_PATH.
LOCAL_REJECTS_PATH=/opt/airflow/data/rejected_data.csv
DQ_REPORT_PATH=/opt/airflow/data/dq_report.json

# === 🐳 Docker Container Permissions ===
AIRFLOW_UID=1000
AIRFLOW_GID=0
